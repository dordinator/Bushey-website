---
import Base from "../../layouts/Base.astro";
import WaterCanvas from "../../components/WaterCanvas.astro";
import WaveDivider from "../../components/WaveDivider.astro";
import CtaBand from "../../components/CtaBand.astro";

// The decades. Club-specific detail is being gathered by the history project;
// entries marked `wanted` render as an open call for memories.
function formatYearLabel(year: string) {
  return year.replace(/s/g, '<span class="text-[0.55em] align-baseline">s</span>');
}

const decades = [
  {
    year: "1926",
    title: "The club is founded",
    body: "King George's open-air pool at the Rec had only just opened in July 1925, civic ceremony and all, and by the next season we'd organised ourselves into Bushey Amateur Swimming Club. We trained in that new municipal pool with a constitution built on one idea that's still with us today: sound swimming technique, properly taught.",
    source: { label: "BASC Welcome Pack", href: "https://www.busheyasc.org/policies/BASC%20Welcome%20Pack.pdf" },
    wanted: false,
  },
  {
    year: "1930s",
    title: "Summers at the lido",
    body: "The King George pool wasn't just ours; it was the place. Bushey Museum has a photograph from about 1934 or '35 of Watford Girls' Grammar holding their gala in our open-air pool. Woollen costumes, packed spectators, summers that seemed to last forever. If you've got programmes or medals from those inter-war galas, we'd love to see them.",
    source: { label: "Bushey Museum", href: "https://busheymuseum.org/journals/" },
    wanted: true,
  },
  {
    year: "1940s–50s",
    title: "Through the war and after",
    body: "The war years are a blur in what we've found. The Rec carried on as a civic swimming venue, but who kept Bushey swimming through the '40s is still patchy in our records. What we do know is the pool came back properly: filtration and purification in the '50s, more people through the turnstiles, and by '59 they were running timed sessions just to cope with the queues. The August end-of-season gala was the highlight of every summer.",
    source: { label: "King George Recreation Ground history", href: "https://www.hertsmere.gov.uk/asset-library/imported-assets/08-Parks-Leisure/Parks-Open-Spaces/Park-facilities/Bushey/king-george-recreation-ground-leaflet.pdf" },
    wanted: true,
  },
  {
    year: "1960s–70s",
    title: "The boom decades",
    body: "Television Olympics on in the background, flared tracksuits on poolside. The open-air pool at King George was in its prime. By the hot summer of '76 you could barely find space in the water. League galas, minibuses to meets, names being engraved on trophies some of us still recognise on the honours board. If you swam in those decades, you remember the smell of the changing rooms and the sting of cold water in April.",
    source: { label: "King George Recreation Ground history", href: "https://www.hertsmere.gov.uk/asset-library/imported-assets/08-Parks-Leisure/Parks-Open-Spaces/Park-facilities/Bushey/king-george-recreation-ground-leaflet.pdf" },
    wanted: true,
  },
  {
    year: "1980s–90s",
    title: "Leagues and generations",
    body: "The August galas, the league trips in rattling minibuses. This is the era a lot of today's parents actually remember swimming. Then came the break: King George pool closed in '89, and by '93 the site was grassed over. We didn't disappear. We spread across school pools and leisure centres, but something of Bushey swimming went with that lido.",
    source: { label: "King George Recreation Ground history", href: "https://www.hertsmere.gov.uk/asset-library/imported-assets/08-Parks-Leisure/Parks-Open-Spaces/Park-facilities/Bushey/king-george-recreation-ground-leaflet.pdf" },
    wanted: true,
  },
  {
    year: "2000s–10s",
    title: "The modern club takes shape",
    body: "Bushey Grove became home and you could feel the club settling into its modern shape. Our 2004 newsletter has us raising money for Sports Relief there; by 2005 we were in the Peanuts League with lessons at John Owen on Merry Hill Road and masters heading to Herts competitions. The 2015 season broke records, more club records than ever, more swimmers at Regionals, and we marked our 90th with a restructure and a swim4fitness group for those of us who still loved the water but weren't chasing medals.",
    source: { label: "BASC 2015 AGM minutes", href: "https://www.busheyasc.org/agm_files/2015agm/BASC%20AGM%20Jan%202016.pdf" },
    wanted: false,
  },
  {
    year: "2026",
    title: "One hundred years",
    body: "One hundred years. Over two hundred members training from Bushey Grove out to St Margaret's, Merchant Taylors, St Helens and Luton. SwimMark accredited again, the centenary badge on the kit, galas and trophy cabinets being dusted off. A party a hundred years in the making. And then, the second century begins.",
    source: { label: "Swim England Poolfinder", href: "https://www.swimming.org/poolfinder/clubs/666/1003797/Bushey%2BAmateur%2BSwimming%2BClub/" },
    wanted: false,
  },
];
---

<Base
  title="Centenary 1926–2026"
  description="Bushey ASC turns one hundred. Explore the timeline of a century in the water, and help the history project tell the club's story."
>
  <!-- Dark hero: the one page that earns the full-drama treatment -->
  <section class="relative overflow-hidden bg-deep-950 text-white">
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(120% 90% at 80% 0%, var(--color-deep-700) 0%, transparent 55%),
        radial-gradient(100% 80% at 10% 100%, var(--color-deep-800) 0%, transparent 60%),
        var(--color-deep-950);"
      aria-hidden="true"
    >
    </div>
    <WaterCanvas />

    <div class="relative mx-auto max-w-7xl px-5 pb-32 pt-36 text-center sm:px-8 sm:pb-44 sm:pt-48">
      <img
        src="/images/centenary-badge.png"
        alt=""
        class="reveal mx-auto mb-6 h-24 w-24 object-contain sm:h-28 sm:w-28"
        width="112"
        height="112"
      />
      <p class="eyebrow reveal text-gold-400">The centenary</p>
      <h1 class="display reveal mt-6 text-[clamp(4rem,14vw,11rem)] leading-none" style="--reveal-delay: 0.08s">
        <span class="shimmer-text">1926–2026</span>
      </h1>
      <p class="reveal mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-white/70 sm:text-xl" style="--reveal-delay: 0.18s">
        One hundred years of chlorine, personal bests and friendships made in lane
        three. This page is where we tell the story, and we need your help to finish it.
      </p>
      <div class="gold-rule reveal mx-auto mt-10 max-w-md" style="--reveal-delay: 0.26s"></div>

      <a href="#timeline" class="scroll-cue reveal group mx-auto mt-12 flex w-fit flex-col items-center gap-3" style="--reveal-delay: 0.34s">
        <span class="eyebrow text-white/60 transition group-hover:text-white">Scroll through the decades</span>
        <span class="scroll-cue__chevron flex h-11 w-11 items-center justify-center rounded-full border border-white/25 text-gold-400 transition group-hover:border-gold-400" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </span>
      </a>
    </div>

    <WaveDivider fill="#ffffff" />
  </section>

  <!-- Scroll-driven timeline -->
  <section id="timeline" class="scroll-mt-24 bg-white py-16 sm:py-24" data-timeline>
    <div class="mx-auto max-w-4xl px-5 sm:px-8">
      <div class="relative">
        <!-- Track + scroll-driven progress line -->
        <div class="absolute bottom-0 left-6 top-0 w-0.5 bg-foam-200 sm:left-1/2 sm:-translate-x-1/2" aria-hidden="true"></div>
        <div
          class="absolute left-6 top-0 w-0.5 origin-top bg-gradient-to-b from-aqua-500 via-aqua-400 to-gold-400 sm:left-1/2 sm:-translate-x-1/2"
          style="height: 100%; transform: scaleY(0);"
          data-timeline-progress
          aria-hidden="true"
        >
        </div>

        <ol class="space-y-14 sm:space-y-20">
          {
            decades.map((d, i) => (
              <li class="relative pl-16 sm:pl-0">
                <span
                  class:list={[
                    "absolute left-6 top-1 flex h-5 w-5 -translate-x-1/2 items-center justify-center rounded-full border-4 border-white shadow-md sm:left-1/2",
                    d.year === "2026" ? "bg-gold-400" : "bg-aqua-500",
                  ]}
                  aria-hidden="true"
                />
                <div
                  class:list={[
                    "reveal sm:w-[calc(50%-2.5rem)]",
                    i % 2 === 0 ? "sm:mr-auto sm:text-right" : "sm:ml-auto",
                  ]}
                >
                  <span class:list={["display text-5xl sm:text-6xl", d.year === "2026" ? "text-gold-400" : "text-foam-200"]} set:html={formatYearLabel(d.year)} />
                  <h2 class="display mt-2 text-2xl text-deep-800">{d.title}</h2>
                  <p class="mt-3 leading-relaxed text-ink-600">{d.body}</p>
                  <p class="mt-3 text-xs text-ink-500">
                    Source:{" "}
                    <a
                      href={d.source.href}
                      target="_blank"
                      rel="noopener"
                      class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600"
                    >
                      {d.source.label} ↗
                    </a>
                  </p>
                  {d.wanted && (
                    <p class:list={["mt-3 inline-block rounded-full bg-gold-400/15 px-4 py-1.5 text-xs font-bold text-gold-500"]}>
                      Memories wanted, can you help?
                    </p>
                  )}
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- History project call -->
  <section class="bg-foam-50 py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="reveal overflow-hidden rounded-3xl bg-deep-900 text-white">
        <div class="grid lg:grid-cols-2">
          <div class="p-8 sm:p-12">
            <p class="eyebrow text-gold-400">The history project</p>
            <h2 class="display mt-3 text-3xl">Help us fill the gaps</h2>
            <p class="mt-4 leading-relaxed text-white/70">
              A hundred years of swimmers means a hundred years of attics. If you, your parents or
              your grandparents swam with Bushey at any point since 1926, we want to hear from you.
            </p>
            <a
              href="mailto:history@busheyasc.org"
              class="mt-8 inline-flex items-center gap-3 rounded-full bg-gold-400 px-7 py-3.5 text-sm font-bold text-deep-900 transition hover:bg-gold-300"
            >
              history@busheyasc.org
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="border-t border-white/10 p-8 sm:p-12 lg:border-l lg:border-t-0">
            <p class="eyebrow text-aqua-400">What we're looking for</p>
            <ul class="mt-4 space-y-3 text-sm leading-relaxed text-white/75">
              <li class="flex gap-3"><span class="text-gold-400" aria-hidden="true">◆</span> Photographs, galas, teams, presentations, poolside</li>
              <li class="flex gap-3"><span class="text-gold-400" aria-hidden="true">◆</span> Gala programmes, results sheets and certificates</li>
              <li class="flex gap-3"><span class="text-gold-400" aria-hidden="true">◆</span> Medals, trophies and old club kit</li>
              <li class="flex gap-3"><span class="text-gold-400" aria-hidden="true">◆</span> Memories and stories, written or told, we'll record them</li>
              <li class="flex gap-3"><span class="text-gold-400" aria-hidden="true">◆</span> Names, help us identify faces in what we already have</li>
            </ul>
          </div>
        </div>
      </div>

      <p class="reveal mt-8 text-center text-sm text-ink-600">
        Centenary events for 2026 will be announced in <a href="/news" class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4">club news</a> throughout the year.
      </p>
    </div>
  </section>

  <CtaBand
    title="Be part of the second century"
    strap="There's never been a better year to join Bushey ASC. New members of all abilities welcome."
  />
</Base>

<style>
  /* Gentle bob on the scroll cue so it reads as "there's more below" */
  .scroll-cue__chevron {
    animation: scroll-cue-bob 1.8s var(--ease-swim) infinite;
  }
  @keyframes scroll-cue-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue__chevron { animation: none; }
  }
</style>

<script>
  // Scroll-driven progress line for the centenary timeline.
  const timeline = document.querySelector("[data-timeline]");
  const progress = document.querySelector("[data-timeline-progress]");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (timeline instanceof HTMLElement && progress instanceof HTMLElement) {
    if (reduced) {
      progress.style.transform = "scaleY(1)";
    } else {
      const update = () => {
        const rect = timeline.getBoundingClientRect();
        const viewH = window.innerHeight;
        // Progress: how far the viewport midpoint has travelled through the section.
        const total = rect.height;
        const passed = Math.min(Math.max(viewH * 0.55 - rect.top, 0), total);
        progress.style.transform = `scaleY(${passed / total})`;
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update, { passive: true });
    }
  }
</script>
