---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import WaveDivider from "../components/WaveDivider.astro";
import SquadPathway from "../components/SquadPathway.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import { upcomingGalas } from "../data/galas";

const news = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const galas = upcomingGalas(
  (await getCollection("fixtures")).map((f) => f.data),
  4,
);

const hub = (await getCollection("hub")).sort((a, b) => a.data.order - b.data.order);

const MONTH_SHORT = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
---

<Base title={site.shortName} description="Bushey Amateur Swimming Club, a small, friendly, volunteer-run club at Bushey Grove teaching sound technique to swimmers aged 5 to 18, from first lengths to county galas. New members of all abilities welcome.">
  <!-- ============ HERO (photo collage) ============ -->
  <section class="relative overflow-hidden bg-foam-50 pt-28 pb-24 sm:pt-32 sm:pb-32">
    <div class="mx-auto grid w-full max-w-7xl items-center gap-10 px-5 sm:px-8 lg:grid-cols-[minmax(0,37rem)_minmax(0,1fr)] lg:gap-14">
      <!-- Title -->
      <div>
        <h1 class="display reveal text-[clamp(2.6rem,5.4vw,4.6rem)] text-deep-900" style="--reveal-delay: 0.08s">
          A century of Bushey swimming
        </h1>

        <p class="reveal mt-6 max-w-md text-base leading-relaxed text-ink-600 sm:text-lg" style="--reveal-delay: 0.14s">
          A small, friendly, volunteer-run club at Bushey Grove — our qualified coaches help
          swimmers aged 5 to 18 build sound technique, from first lengths to county galas.
          New members of all abilities welcome.
        </p>

        <div class="reveal mt-8 flex flex-wrap items-center gap-x-6 gap-y-3.5 lg:flex-nowrap" style="--reveal-delay: 0.2s">
          <a href="/join" class="btn-primary press whitespace-nowrap">Join the club <span aria-hidden="true">→</span></a>
          <a href="/compete/fixtures" class="btn-outline press whitespace-nowrap">Upcoming galas <span aria-hidden="true">→</span></a>
          <a href="/train/squads" class="btn-quiet swim-link whitespace-nowrap">Meet the squads <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <!-- Photo collage. Tiles auto-rotate (one at a time, never a duplicate). -->
      <div class="hero-collage reveal h-[440px] lg:h-[560px]" style="--reveal-delay: 0.15s" data-collage>
        <div class="hero-tile" style="grid-column: 1 / 5; grid-row: 1 / 4;">
          <img src="/images/team-trophy.jpg" alt="The Bushey ASC squad with their trophy" style="object-position: center 42%;" />
          <span class="display" style="position:absolute; left:12px; bottom:12px; background: var(--color-gold-400); color: var(--color-deep-900); font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 999px;">100 years in 2026</span>
        </div>
        <div class="hero-tile" style="grid-column: 5 / 7; grid-row: 1 / 5;">
          <img src="/images/team-gala.jpg" alt="Bushey ASC swimmers at a gala" style="object-position: center 30%;" />
        </div>
        <div class="hero-tile" style="grid-column: 1 / 3; grid-row: 4 / 7;">
          <img src="/images/medals-four.jpg" alt="Bushey swimmers with their medals" style="object-position: center 18%;" />
        </div>
        <div class="hero-tile" style="grid-column: 3 / 5; grid-row: 4 / 7;">
          <img src="/images/mayor.jpg" alt="A Bushey swimmer meets the mayor" style="object-position: center 30%;" />
        </div>
        <div class="hero-tile" style="grid-column: 5 / 7; grid-row: 5 / 7;">
          <img src="/images/news-herts-aquatics-1.jpeg" alt="Young swimmers with medals" style="object-position: center 12%;" />
        </div>
      </div>
    </div>

    <WaveDivider fill="var(--color-gold-400)" height="h-10 sm:h-16" class="z-10" />
  </section>

  <!-- ============ CENTENARY BAND ============ -->
  <section class="bg-gold-400">
    <a href="/club/centenary" class="group block">
      <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-4 px-5 py-8 sm:flex-row sm:items-center sm:px-8">
        <div class="flex items-center gap-5">
          <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-deep-900 p-2.5">
            <img src="/images/centenary-badge.png" alt="" class="h-full w-full object-contain" width="44" height="44" loading="lazy" />
          </span>
          <span class="display text-5xl text-deep-900 sm:text-6xl">1926<span class="text-deep-900/40">–</span>2026</span>
        </div>
        <p class="max-w-md text-sm font-semibold leading-snug text-deep-900/80">
          This is our centenary year. Explore one hundred years of Bushey swimming, and help us
          tell the story.
        </p>
        <span class="inline-flex items-center gap-2 rounded-full bg-deep-900 px-6 py-3 text-sm font-bold text-gold-300 transition group-hover:gap-3.5">
          The centenary <span aria-hidden="true">→</span>
        </span>
      </div>
    </a>
  </section>

  <!-- ============ SQUAD PATHWAY ============ -->
  <section class="relative overflow-hidden bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <SectionHeader
        title="How swimmers progress at Bushey"
        strap="Everyone starts in the same place. Swimmers move up a squad when they're ready — never before — so the route from first lengths to race day is the same for every child. Tap a squad to see what happens there."
      />
      <div class="reveal mt-12" style="--reveal-delay: 0.15s">
        <SquadPathway />
      </div>
      <p class="reveal mt-10 text-sm text-ink-600">
        Not sure where your swimmer would fit? Don't worry about picking — come along for a&nbsp;<a href="/join" class="swim-link font-bold text-aqua-600 hover:text-deep-800">trial swim</a> and the coaches will find the right squad.
      </p>
    </div>
  </section>

  <!-- ============ NEWS + FIXTURES ============ -->
  <section class="bg-foam-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="grid gap-16 lg:grid-cols-[1.6fr_1fr]">
        <!-- News -->
        <div class="flex flex-col">
          <SectionHeader eyebrow="Latest" title="Club news" />
          <a href="/news" class="swim-link reveal mt-2 self-start py-1 text-sm font-bold text-aqua-600 hover:text-deep-800">
            All news →
          </a>
          <div class="mt-8 grid flex-1 auto-rows-fr gap-6">
            {
              news.map((post, i) => (
                <a
                  href={`/news/${post.id}`}
                  class="card-lift reveal group grid overflow-hidden rounded-3xl border border-foam-200 bg-white sm:grid-cols-[180px_1fr]"
                  style={`--reveal-delay: ${i * 0.08}s`}
                >
                  {
                    post.data.image ? (
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt ?? ""}
                        class="h-36 w-full object-cover sm:h-full"
                        width="360"
                        height="240"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex h-36 items-center justify-center bg-deep-900 sm:h-full" aria-hidden="true">
                        <img src="/images/logo-badge.png" alt="" class="h-16 w-16 object-contain opacity-90 invert" width="64" height="64" loading="lazy" />
                      </div>
                    )
                  }
                  <div class="flex flex-col justify-center p-6">
                    <span class="text-xs font-bold uppercase tracking-[0.18em] text-gold-600">
                      {post.data.category} · {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                    </span>
                    <h3 class="mt-1.5 text-xl font-bold text-deep-800 transition group-hover:text-aqua-600">{post.data.title}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-ink-600">{post.data.excerpt}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Upcoming galas -->
        <div class="flex flex-col">
          <SectionHeader eyebrow="On the blocks" title="The season ahead" />
          <a href="/compete/fixtures" class="swim-link reveal mt-2 self-start py-1 text-sm font-bold text-aqua-600 hover:text-deep-800">
            Upcoming galas →
          </a>
          <div class="mt-8 flex flex-1 flex-col overflow-hidden rounded-3xl bg-deep-900">
            {
              galas.map((gala, i) => (
                <div class:list={["reveal flex flex-1 flex-col justify-center p-6", i > 0 && "border-t border-white/10"]} style={`--reveal-delay: ${i * 0.08}s`}>
                  <p class="text-xs font-bold uppercase tracking-wider text-gold-400">{MONTH_SHORT[gala.month - 1]} · {gala.level}</p>
                  <h3 class="mt-1.5 font-bold text-white">{gala.name}</h3>
                  <p class="mt-1 text-sm text-white/55">{gala.typicalTiming}</p>
                </div>
              ))
            }
            <a href="/compete/guide" class="block bg-gold-400 p-5 text-center text-sm font-bold text-deep-900 transition hover:bg-gold-300">
              First gala? Read our competing guide →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ATHLETE HUB TEASER ============ -->
  <section class="relative overflow-hidden bg-white py-20 sm:py-28">
    <div class="pointer-events-none absolute -left-10 bottom-0 select-none" aria-hidden="true">
      <span class="display text-outline text-[14rem] leading-none text-deep-800/8">HUB</span>
    </div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <SectionHeader
        eyebrow="The Athlete Hub"
        title="There's more to it than the pool"
        strap="Food, sleep, land training, kit and recovery. Practical guides from Swim England for our squads and parents."
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          hub.map((article, i) => (
            <a
              href={`/athlete-hub/${article.id}`}
              class="card-lift reveal group flex flex-col rounded-3xl border border-foam-200 bg-foam-50 p-7"
              style={`--reveal-delay: ${(i % 3) * 0.08}s`}
            >
              <span class="display block text-xs text-aqua-600">0{article.data.order}</span>
              <h3 class="display mt-3 text-2xl text-deep-800 transition group-hover:text-aqua-600">{article.data.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-600">{article.data.strap}</p>
              <span class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-bold text-aqua-600 transition group-hover:gap-3">
                Read <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }

        <!-- Where to start: the hub's own guidance, so the section previews the hub properly -->
        <div class="reveal flex flex-col rounded-3xl bg-deep-900 p-7 text-white" style="--reveal-delay: 0.16s">
          <span class="display block text-xs text-gold-400">Where to start</span>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed text-white/75">
            <li class="flex gap-3"><span class="font-bold text-gold-400" aria-hidden="true">1.</span> Parents of younger swimmers: start with Nutrition and the Equipment guide.</li>
            <li class="flex gap-3"><span class="font-bold text-gold-400" aria-hidden="true">2.</span> Competing swimmers: start with Sleep &amp; Recovery.</li>
            <li class="flex gap-3"><span class="font-bold text-gold-400" aria-hidden="true">3.</span> Top squads: all five, then ask your coach how to apply them.</li>
          </ul>
          <p class="mt-4 text-xs leading-relaxed text-white/50">Every guide follows Swim England guidance and links to their resources.</p>
          <a href="/athlete-hub" class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-bold text-gold-300 transition hover:gap-3 hover:text-gold-400">
            Browse the whole hub <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<script>
  // Hero collage auto-rotation: one tile at a time, crossfading, and the same
  // photo can never appear in two tiles at once (it checks what's on screen at
  // swap time). Respects prefers-reduced-motion. Tune SECONDS / CROSSFADE below.
  (() => {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const collage = document.querySelector("[data-collage]");
    if (!collage) return;

    const SECONDS = 8;     // seconds between switches
    const CROSSFADE = 0.8; // crossfade length in seconds

    const pool = [
      { src: "/images/team-trophy.jpg", pos: "center 42%" },
      { src: "/images/team-gala.jpg", pos: "center 30%" },
      { src: "/images/medals-four.jpg", pos: "center 18%" },
      { src: "/images/mayor.jpg", pos: "center 30%" },
      { src: "/images/news-herts-aquatics-1.jpeg", pos: "center 12%" },
      { src: "/images/members-group.jpg", pos: "center 34%" },
      { src: "/images/news-club-champs-group.jpg", pos: "center 30%" },
      { src: "/images/news-herts-aquatics-2.jpeg", pos: "center 42%" },
    ];
    pool.forEach((p) => { const im = new Image(); im.src = p.src; });

    const tiles = Array.from(collage.querySelectorAll(".hero-tile"));
    const onScreen = () => new Set(tiles.map((t) => {
      const imgs = t.querySelectorAll("img");
      const top = imgs[imgs.length - 1];
      return top ? top.getAttribute("src") : null;
    }).filter(Boolean));

    const swap = () => {
      const tile = tiles[Math.floor(Math.random() * tiles.length)];
      const base = tile.querySelector("img");
      const shown = onScreen();
      const opts = pool.filter((p) => !shown.has(p.src));
      if (!opts.length) { setTimeout(swap, 4000); return; }
      const pick = opts[Math.floor(Math.random() * opts.length)];

      const ov = document.createElement("img");
      ov.alt = "";
      ov.style.cssText = `position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity ${CROSSFADE * 1000}ms ease;z-index:2`;
      ov.style.objectPosition = pick.pos;
      const finish = () => {
        tile.appendChild(ov);
        requestAnimationFrame(() => { ov.style.opacity = "1"; });
        setTimeout(() => {
          base.setAttribute("src", pick.src);
          base.style.objectPosition = pick.pos;
          setTimeout(() => ov.remove(), 160);
          setTimeout(swap, SECONDS * 1000 * (0.85 + Math.random() * 0.3));
        }, CROSSFADE * 1000 + 200);
      };
      ov.onload = finish;
      ov.onerror = () => setTimeout(swap, 5000);
      ov.src = pick.src;
      if (ov.complete && ov.naturalWidth) finish();
    };
    setTimeout(swap, SECONDS * 1000);
  })();
</script>
