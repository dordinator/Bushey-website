---
/** Interactive squad pathway — a swimming lane of squads from Dolphins to Performance.
 *  The connecting line is styled like a pool lane rope; each squad sits on it as a
 *  buoy with its own badge. Tap a squad to preview it; panels link to the full page. */
import { getCollection } from "astro:content";

const squads = (await getCollection("squads"))
  .filter((s) => s.data.name !== "Masters")
  .sort((a, b) => a.data.order - b.data.order);
---

<div class="pathway" data-pathway>
  <!-- Lane of squads -->
  <div class="relative">
    <!-- The lane rope: alternating club-colour segments, like the real thing -->
    <div class="lane-rope absolute left-7 top-4 bottom-4 w-1.5 rounded-full lg:left-4 lg:right-4 lg:top-7 lg:bottom-auto lg:h-1.5 lg:w-auto" aria-hidden="true"></div>

    <div class="relative grid gap-1.5 lg:grid-cols-7 lg:gap-0" role="tablist" aria-label="Squad pathway">
      {
        squads.map((squad, i) => (
          <button
            type="button"
            role="tab"
            id={`pathway-tab-${squad.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`pathway-panel-${squad.id}`}
            data-pathway-tab={squad.id}
            class="group relative flex cursor-pointer items-center gap-4 rounded-2xl px-3 py-2 text-left transition hover:bg-foam-50 lg:flex-col lg:gap-2.5 lg:py-3 lg:text-center lg:hover:bg-transparent"
          >
            <span class="pathway-dot relative z-10 flex h-14 w-14 shrink-0 items-center justify-center rounded-full border-2 border-foam-200 bg-white p-2 shadow-sm transition-all duration-300 group-hover:border-gold-400 group-hover:scale-105">
              <img src={`/images/squad-${squad.id}.png`} alt="" class="h-full w-full object-contain" width="40" height="40" loading="lazy" />
            </span>
            <span class="flex flex-col lg:items-center">
              <span class="pathway-label text-sm font-bold text-deep-800 transition">{squad.data.name}</span>
              <span class="text-xs text-ink-400">{squad.data.ageGuide}</span>
            </span>
          </button>
        ))
      }
    </div>
  </div>

  <!-- Detail panels -->
  <div class="mt-8">
    {
      squads.map((squad, i) => (
        <div
          role="tabpanel"
          id={`pathway-panel-${squad.id}`}
          aria-labelledby={`pathway-tab-${squad.id}`}
          data-pathway-panel={squad.id}
          class:list={["rounded-3xl border border-foam-200 bg-foam-50 p-6 sm:p-8", i !== 0 && "hidden"]}
        >
          <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
            <div class="max-w-xl">
              <p class="eyebrow text-aqua-600">{squad.data.tag} · {squad.data.hoursPerWeek} per week</p>
              <h3 class="display mt-1.5 text-3xl text-deep-900">{squad.data.name}</h3>
              <p class="mt-3 leading-relaxed text-ink-600">{squad.data.strap}</p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {squad.data.focus.slice(0, 3).map((f) => (
                  <li class="rounded-full border border-foam-200 bg-white px-3 py-1 text-xs font-semibold text-ink-600">{f}</li>
                ))}
              </ul>
            </div>
            <a href={`/train/squads/${squad.id}`} class="btn-outline press shrink-0">
              Explore {squad.data.name} <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      ))
    }
  </div>

  <p class="mt-6 text-sm text-ink-400">
    Plus our <a href="/train/squads/masters" class="swim-link font-semibold text-aqua-600 hover:text-deep-800">Masters section</a> for adult swimmers, growing through our centenary year.
  </p>
</div>

<style>
  /* Lane rope: alternating yellow / black discs with white spacers, club colours */
  .lane-rope {
    background: repeating-linear-gradient(
      180deg,
      var(--color-gold-400) 0 16px,
      #ffffff 16px 22px,
      var(--color-deep-900) 22px 38px,
      #ffffff 38px 44px
    );
    opacity: 0.85;
  }
  @media (min-width: 1024px) {
    .lane-rope {
      background: repeating-linear-gradient(
        90deg,
        var(--color-gold-400) 0 16px,
        #ffffff 16px 22px,
        var(--color-deep-900) 22px 38px,
        #ffffff 38px 44px
      );
    }
  }

  [data-pathway-tab][aria-selected="true"] .pathway-dot {
    border-color: var(--color-gold-400);
    background: var(--color-gold-400);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--color-gold-400) 45%, transparent);
  }
  [data-pathway-tab][aria-selected="true"] .pathway-label {
    color: var(--color-deep-900);
  }
</style>

<script>
  document.querySelectorAll("[data-pathway]").forEach((root) => {
    const tabs = root.querySelectorAll("[data-pathway-tab]");
    const panels = root.querySelectorAll("[data-pathway-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const id = tab.getAttribute("data-pathway-tab");
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
        panels.forEach((p) => {
          p.classList.toggle("hidden", p.getAttribute("data-pathway-panel") !== id);
        });
      });
    });
  });
</script>
